# Warframe market dashboard — reverse proxy + static file server.
#
# Binds to LOOPBACK ONLY (:8080). Cloudflare Tunnel (cloudflared) connects here
# from inside the same container; nothing else can reach this port and the
# container firewall denies inbound anyway. Public TLS is terminated at
# Cloudflare's edge, so Caddy doesn't manage a public cert here.
#
# If you ever drop Cloudflare and port-forward instead, change `:8080` to your
# domain (e.g. `wfm.example.com { ... }`) and Caddy auto-issues a Let's Encrypt
# cert — but only adopt HSTS once HTTPS on that domain is permanent.

:8080 {
	root * /srv/wfm/app/prototype/dist
	encode gzip zstd

	# Security headers — copied verbatim from prototype/public/_headers.
	# GitHub Pages silently dropped these; applying them for real is the whole
	# reason to self-host. Verify after deploy: `curl -sI https://<host> | grep -i strict`.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		Content-Security-Policy "default-src 'self'; connect-src 'self' https://api.warframestat.us http://127.0.0.1:* http://localhost:*; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
		-Server
	}

	# Serve the cron-refreshed market.json from the repo's public/ (the live file
	# the scrape rewrites atomically), shadowing the stale copy Vite baked into
	# dist/. Short cache — the data turns over ~every 2h.
	handle /market.json {
		root * /srv/wfm/app/prototype/public
		header Cache-Control "public, max-age=300, must-revalidate"
		file_server
	}

	# Content-addressed Vite assets never change → cache hard.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# SPA fallback: real files win, otherwise serve index.html.
	file_server
	try_files {path} /index.html
}
