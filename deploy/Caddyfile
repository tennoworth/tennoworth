# Warframe market dashboard — a SITE BLOCK to add to your EXISTING Caddyfile.
#
# You already run Caddy + a Cloudflare Tunnel, so DON'T replace your Caddyfile
# with this — paste this block in (or `import` it). Pick a localhost port that's
# free on your box (8080 is a common collision; 8081 used here), point a NEW
# tunnel public hostname (e.g. wfm.yourdomain.com -> http://localhost:8081) at
# it, and adjust the port below to match.
#
# Binds to loopback only — the tunnel reaches it; nothing else can.

:8081 {
	root * /srv/wfm/app/prototype/dist
	encode gzip zstd

	# Security headers — from prototype/public/_headers, with ONE deliberate change:
	# HSTS here is `max-age` only. The canonical set adds `includeSubDomains; preload`,
	# which is an APEX-WIDE, hard-to-undo commitment (it forces HTTPS on every sibling
	# subdomain for a year, and `preload` gets baked into browsers). That's wrong for a
	# single subdomain sharing a domain with your other services. Re-add those two only
	# if you own the apex and intend HTTPS across ALL of it. Verify the headers land:
	#   curl -sI https://wfm.yourdomain.com | grep -iE 'strict-transport|frame|content-security'
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		Content-Security-Policy "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
		-Server
	}

	# Live, cron-refreshed data files from public/ (shadow the stale copies Vite
	# bakes into dist/). wfstat-catalog.json backs the inventory resolver — the
	# browser stopped fetching warframestat directly when upstream dropped CORS.
	# Its own handle block so routing is unambiguous.
	@livedata path /market.json /wfstat-catalog.json
	handle @livedata {
		root * /srv/wfm/app/prototype/public
		header Cache-Control "public, max-age=300, must-revalidate"
		file_server
	}

	# Everything else: the SPA. Wrapped in a catch-all handle so we never mix a
	# handle block with bare file_server/try_files (Caddy's directive ordering
	# there is surprising). try_files rewrites unknown paths to index.html.
	handle {
		@assets path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"
		try_files {path} /index.html
		file_server
	}
}
