{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TennoWorth",
  "version": "0.1.0",
  "identifier": "app.tennoworth.desktop",
  "build": {
    "frontendDist": "../../prototype/dist-desktop",
    "beforeDevCommand": "cd ../prototype && bun run build:desktop",
    "beforeBuildCommand": "cd ../prototype && bun run build:desktop"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "PLACEHOLDER-NOT-A-REAL-KEY: generate the updater keypair OFFLINE with `cargo tauri signer generate` and paste the .pub file contents here — docs/signing-runbook.md section 9. Until then every signature check fails and no update can ever install.",
      "endpoints": [
        "https://github.com/tennoworth/tennoworth/releases/latest/download/latest.json"
      ]
    }
  }
}
